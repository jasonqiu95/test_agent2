{
  "id": "garamond",
  "name": "Garamond Elegance",
  "description": "A timeless old-style serif typeface with graceful curves, ideal for poetry and literary works.",
  "category": "serif",
  "fonts": {
    "body": "'Garamond', 'EB Garamond', 'Cormorant Garamond'",
    "heading": "'Garamond', 'EB Garamond', 'Cormorant Garamond'",
    "fallback": "serif"
  },
  "headings": {
    "h1": {
      "fontSize": "2.75em",
      "fontWeight": "500",
      "lineHeight": "1.15",
      "marginTop": "2em",
      "marginBottom": "1em",
      "textTransform": "capitalize",
      "letterSpacing": "0.03em"
    },
    "h2": {
      "fontSize": "2em",
      "fontWeight": "500",
      "lineHeight": "1.3",
      "marginTop": "1.75em",
      "marginBottom": "0.6em",
      "letterSpacing": "0.02em"
    },
    "h3": {
      "fontSize": "1.5em",
      "fontWeight": "500",
      "lineHeight": "1.4",
      "marginTop": "1.5em",
      "marginBottom": "0.5em"
    }
  },
  "body": {
    "fontSize": "1.15em",
    "lineHeight": "1.8",
    "textAlign": "justify"
  },
  "dropCap": {
    "enabled": true,
    "lines": 4,
    "fontSize": "4.5em",
    "fontWeight": "500",
    "marginRight": "0.12em",
    "color": "#6b4423"
  },
  "ornamentalBreak": {
    "enabled": true,
    "symbol": "✦ ✦ ✦",
    "spacing": "2.5em",
    "fontSize": "1em"
  },
  "firstParagraph": {
    "enabled": true,
    "fontVariant": "small-caps",
    "letterSpacing": "0.08em",
    "fontSize": "1em"
  },
  "spacing": {
    "paragraphSpacing": "1.3em",
    "lineHeight": "1.8",
    "sectionSpacing": "3.5em",
    "chapterSpacing": "6em"
  },
  "colors": {
    "text": "#333333",
    "heading": "#1f1f1f",
    "accent": "#6b4423",
    "background": "#fffef9",
    "dropCap": "#6b4423"
  }
}
