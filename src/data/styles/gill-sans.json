{
  "id": "gill-sans",
  "name": "Gill Sans Humanist",
  "description": "A British humanist sans-serif with classic proportions, perfect for travel writing and cultural essays.",
  "category": "sans-serif",
  "fonts": {
    "body": "'Gill Sans', 'Lato', 'Trebuchet MS'",
    "heading": "'Gill Sans', 'Lato', 'Trebuchet MS'",
    "fallback": "sans-serif"
  },
  "headings": {
    "h1": {
      "fontSize": "2.6em",
      "fontWeight": "700",
      "lineHeight": "1.15",
      "marginTop": "1.6em",
      "marginBottom": "0.7em",
      "textTransform": "uppercase",
      "letterSpacing": "0.04em"
    },
    "h2": {
      "fontSize": "2em",
      "fontWeight": "600",
      "lineHeight": "1.25",
      "marginTop": "1.4em",
      "marginBottom": "0.6em",
      "letterSpacing": "0.02em"
    },
    "h3": {
      "fontSize": "1.5em",
      "fontWeight": "600",
      "lineHeight": "1.35",
      "marginTop": "1.2em",
      "marginBottom": "0.5em"
    }
  },
  "body": {
    "fontSize": "1.08em",
    "lineHeight": "1.65",
    "fontWeight": "400",
    "textAlign": "left"
  },
  "dropCap": {
    "enabled": true,
    "lines": 2,
    "fontSize": "3.5em",
    "fontWeight": "700",
    "marginRight": "0.1em",
    "color": "#d35400"
  },
  "ornamentalBreak": {
    "enabled": true,
    "symbol": "◦ ◦ ◦",
    "spacing": "2em",
    "fontSize": "1em"
  },
  "firstParagraph": {
    "enabled": true,
    "textTransform": "uppercase",
    "letterSpacing": "0.08em",
    "fontSize": "0.88em"
  },
  "spacing": {
    "paragraphSpacing": "1.15em",
    "lineHeight": "1.65",
    "sectionSpacing": "2.8em",
    "chapterSpacing": "4.5em"
  },
  "colors": {
    "text": "#2f2f2f",
    "heading": "#1a1a1a",
    "accent": "#d35400",
    "background": "#ffffff",
    "dropCap": "#d35400"
  }
}
