{
  "id": "futura",
  "name": "Futura Bold",
  "description": "A geometric sans-serif with strong modernist character, perfect for avant-garde and design-focused books.",
  "category": "modern",
  "fonts": {
    "body": "'Futura', 'Century Gothic', 'Avenir'",
    "heading": "'Futura', 'Century Gothic', 'Avenir'",
    "fallback": "sans-serif"
  },
  "headings": {
    "h1": {
      "fontSize": "3em",
      "fontWeight": "700",
      "lineHeight": "1.1",
      "marginTop": "1.5em",
      "marginBottom": "0.5em",
      "textTransform": "uppercase",
      "letterSpacing": "0.08em"
    },
    "h2": {
      "fontSize": "2.2em",
      "fontWeight": "600",
      "lineHeight": "1.2",
      "marginTop": "1.3em",
      "marginBottom": "0.5em",
      "letterSpacing": "0.05em"
    },
    "h3": {
      "fontSize": "1.6em",
      "fontWeight": "600",
      "lineHeight": "1.3",
      "marginTop": "1.2em",
      "marginBottom": "0.4em",
      "letterSpacing": "0.03em"
    }
  },
  "body": {
    "fontSize": "1em",
    "lineHeight": "1.6",
    "fontWeight": "400",
    "textAlign": "left"
  },
  "dropCap": {
    "enabled": true,
    "lines": 2,
    "fontSize": "3.8em",
    "fontWeight": "900",
    "marginRight": "0.08em",
    "color": "#e63946"
  },
  "ornamentalBreak": {
    "enabled": true,
    "symbol": "■",
    "spacing": "2em",
    "fontSize": "1em"
  },
  "firstParagraph": {
    "enabled": true,
    "textTransform": "uppercase",
    "letterSpacing": "0.12em",
    "fontSize": "0.85em"
  },
  "spacing": {
    "paragraphSpacing": "1em",
    "lineHeight": "1.6",
    "sectionSpacing": "2.5em",
    "chapterSpacing": "4em"
  },
  "colors": {
    "text": "#2b2d42",
    "heading": "#1a1a2e",
    "accent": "#e63946",
    "background": "#ffffff",
    "dropCap": "#e63946"
  }
}
