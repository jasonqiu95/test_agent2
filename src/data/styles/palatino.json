{
  "id": "palatino",
  "name": "Palatino Traditional",
  "description": "A distinguished old-style serif inspired by Italian Renaissance, excellent for memoirs and biographies.",
  "category": "serif",
  "fonts": {
    "body": "'Palatino', 'Palatino Linotype', 'Book Antiqua'",
    "heading": "'Palatino', 'Palatino Linotype', 'Book Antiqua'",
    "fallback": "serif"
  },
  "headings": {
    "h1": {
      "fontSize": "2.7em",
      "fontWeight": "700",
      "lineHeight": "1.2",
      "marginTop": "2.2em",
      "marginBottom": "0.8em",
      "textTransform": "capitalize",
      "letterSpacing": "0.02em"
    },
    "h2": {
      "fontSize": "2.1em",
      "fontWeight": "600",
      "lineHeight": "1.3",
      "marginTop": "1.8em",
      "marginBottom": "0.7em",
      "letterSpacing": "0.01em"
    },
    "h3": {
      "fontSize": "1.6em",
      "fontWeight": "600",
      "lineHeight": "1.4",
      "marginTop": "1.5em",
      "marginBottom": "0.6em",
      "fontStyle": "italic"
    }
  },
  "body": {
    "fontSize": "1.12em",
    "lineHeight": "1.75",
    "textAlign": "justify"
  },
  "dropCap": {
    "enabled": true,
    "lines": 4,
    "fontSize": "4.8em",
    "fontWeight": "700",
    "marginRight": "0.12em",
    "color": "#5a3e2b"
  },
  "ornamentalBreak": {
    "enabled": true,
    "symbol": "✽",
    "spacing": "2.5em",
    "fontSize": "1.6em"
  },
  "firstParagraph": {
    "enabled": true,
    "fontVariant": "small-caps",
    "letterSpacing": "0.07em",
    "fontSize": "0.95em"
  },
  "spacing": {
    "paragraphSpacing": "1.3em",
    "lineHeight": "1.75",
    "sectionSpacing": "3.5em",
    "chapterSpacing": "6em"
  },
  "colors": {
    "text": "#323232",
    "heading": "#1e1e1e",
    "accent": "#5a3e2b",
    "background": "#fffef8",
    "dropCap": "#5a3e2b"
  }
}
